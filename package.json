{
  "name": "atomdoc-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:docs": "npm run dev --workspace=atom-docs",
    "dev:portal": "npm run dev --workspace=portal",
    "build:docs": "npm run build --workspace=atom-docs",
    "build:portal": "npm run build --workspace=portal",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
